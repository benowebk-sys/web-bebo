{
  "version": 2,
  "builds": [
    {
      "src": "backend/server.js",
      "use": "@vercel/node"
    },
    {
      "src": "frontend/**",
      "use": "@vercel/static"
    }
  ],
  "installCommand": "cd backend && npm install",
  "routes": [
    {
      "src": "^/api/(.*)$",
      "dest": "backend/server.js"
    },
    {
      "src": "^/$",
      "dest": "frontend/index.html"
    },
    {
      "src": "^/(.*)$",
      "dest": "frontend/$1"
    }
  ]
}
