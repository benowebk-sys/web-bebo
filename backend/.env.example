# Supabase Configuration
SUPABASE_URL=https://your-project.supabase.co
SUPABASE_SERVICE_ROLE_KEY=your-service-role-key

# JWT Secret (generate a strong random string, minimum 32 characters)
JWT_SECRET=your-super-secret-key-change-this-1234567890

# Admin Credentials
ADMIN_EMAIL=admin@example.com
ADMIN_PASSWORD=StrongAdminPassword123!

# Frontend URL (for CORS validation)
FRONTEND_URL=https://your-frontend.vercel.app

# Proxy settings
# For Vercel, set trust proxy to 1 so Express reads the correct client IP
TRUST_PROXY=1

# Redis settings (optional, recommended for production rate limiting)
# If not provided, the app falls back to in-memory rate limiting.
REDIS_HOST=127.0.0.1
REDIS_PORT=6379
REDIS_PASSWORD=your-redis-password
